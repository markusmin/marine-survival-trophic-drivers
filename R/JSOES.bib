@article{hurtado-ferro_looking_2015,
  title = {Looking in the Rear-View Mirror: Bias and Retrospective Patterns in Integrated, Age-Structured Stock Assessment Models},
  shorttitle = {Looking in the Rear-View Mirror},
  author = {{Hurtado-Ferro}, Felipe and Szuwalski, Cody S and Valero, Juan L and Anderson, Sean C and Cunningham, Curry J and Johnson, Kelli F and Licandeo, Roberto and McGilliard, Carey R and Monnahan, Cole C and Muradian, Melissa L and Ono, Kotaro and {Vert-Pre}, Katyana A and Whitten, A R and Punt, A E},
  year = 2015,
  month = jan,
  journal = {ICES Journal of Marine Science},
  volume = {72},
  number = {1},
  pages = {99--110},
  issn = {1054-3139, 1095-9289},
  doi = {10.1093/icesjms/fsu198},
  urldate = {2019-06-07},
  abstract = {Retrospective patterns are systematic changes in estimates of population size, or other assessment model-derived quantities, that occur as additional years of data are added to, or removed from, a stock assessment. These patterns are an insidious problem, and can lead to severe errors when providing management advice. Here, we use a simulation framework to show that temporal changes in selectivity, natural mortality, and growth can induce retrospective patterns in integrated, age-structured models. We explore the potential effects on retrospective patterns of catch history patterns, as well as model misspecification due to not accounting for time-varying biological parameters and selectivity. We show that non-zero values for Mohn's r (a common measure for retrospective patterns) can be generated even where there is no model misspecification, but the magnitude of Mohn's r tends to be lower when the model is not misspecified. The magnitude and sign of Mohn's r differed among life histories, with different life histories reacting differently from each type of temporal change. The value of Mohn's r is not related to either the sign or magnitude of bias in the estimate of terminal year biomass. We propose a rule of thumb for values of Mohn's r which can be used to determine whether a stock assessment shows a retrospective pattern.}
}

@article{Huson2016,
  title = {{{MEGAN Community Edition}} - {{Interactive Exploration}} and {{Analysis}} of {{Large-Scale Microbiome Sequencing Data}}},
  author = {Huson, Daniel H. and Beier, Sina and Flade, Isabell and G{\'o}rska, Anna and {El-Hadidi}, Mohamed and Mitra, Suparna and Ruscheweyh, Hans Joachim and Tappu, Rewati},
  year = 2016,
  journal = {PLoS Computational Biology},
  volume = {12},
  number = {6},
  pages = {1--12},
  issn = {15537358},
  doi = {10.1371/journal.pcbi.1004957},
  abstract = {There is increasing interest in employing shotgun sequencing, rather than amplicon sequencing, to analyze microbiome samples. Typical projects may involve hundreds of samples and billions of sequencing reads. The comparison of such samples against a protein reference database generates billions of alignments and the analysis of such data is computationally challenging. To address this, we have substantially rewritten and extended our widely-used microbiome analysis tool MEGAN so as to facilitate the interactive analysis of the taxonomic and functional content of very large microbiome datasets. Other new features include a functional classifier called InterPro2GO, gene-centric read assembly, principal coordinate analysis of taxonomy and function, and support for metadata. The new program is called MEGAN Community Edition (CE) and is open source. By integrating MEGAN CE with our high-throughput DNA-to-protein alignment tool DIAMOND and by providing a new program MeganServer that allows access to metagenome analysis files hosted on a server, we provide a straightforward, yet powerful and complete pipeline for the analysis of metagenome shotgun sequences. We illustrate how to perform a full-scale computational analysis of a metagenomic sequencing project, involving 12 samples and 800 million reads, in less than three days on a single server. All source code is available here: https://github.com/danielhuson/megan-ce},
  file = {/Users/markusmin/Zotero/storage/QMBPT3A3/MEGAN_paper.pdf}
}

@article{huyerPeruUndercurrentStudy1991,
  title = {The {{Peru Undercurrent}}: A Study in Variability},
  author = {Huyer, Adriana and Knoll, Michaela and Paluszkiewicz, Theresa and Smith, Robert L.},
  year = 1991,
  month = jan,
  journal = {Deep Sea Research Part A. Oceanographic Research Papers},
  volume = {38},
  pages = {S247-S271},
  publisher = {Elsevier BV},
  issn = {01980149},
  doi = {10.1016/s0198-0149(12)80012-4},
  urldate = {2020-07-13},
  abstract = {Moored current meter measurements over the inner continental margin off Peru began in November 1981 at 5{$^\circ$} and 10{$^\circ$}S and continued until March 1985. Although disturbances, ranging from El Ni\~no to long-line fishing and biological fouling, hindered obtaining an adequate description of the Peru Undercurrent at 5{$^\circ$}S, the measurements at 10{$^\circ$}S from October 1983 to March 1985 do provide a stationary description. The dominant variability is in the 50-day band; a relationship to the ubiquitous tropical atmospheric oscillation and to the Equatorial Undercurrent is suggested at these frequencies. The Peru Undercurrent flows poleward over the inner slope and outer shelf with a well-defined core near 150m, where the O(100 day) mean speed is O(l0 cms -1) with periods of several days to 2 weeks during which sustained poleward flow exceeds 25 cm s-1. Geostrophic and direct measurements are in good agreement as to location and structure of the poleward How but magnitudes may differ by a factor of two. The transport of the Peru Undercurrent is about 1 Sv at 10{$^\circ$}S and has the proper depth, location and magnitude to supply the coastal upwelling to at least 15{$^\circ$}S. Variability in the 10- and 20-day band can be traced to variability in the meridional component of equatorial currents near 110{$^\circ$}W. The Peru Undercurrent exhibited no seasonal cycle but high variability at periods longer than 30 days before El Ni\~no and at periods shorter than 20 days during El Ni\~no.}
}

