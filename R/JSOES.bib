@article{parrishSeabirdsIndicatorsExploratory2003,
  title = {Seabirds as Indicators: {{An}} Exploratory Analysis of Physical Forcing in the {{Pacific Northwest}} Coastal Environment},
  shorttitle = {Seabirds as Indicators},
  author = {Parrish, Julia K. and Zador, Stephani G.},
  year = 2003,
  month = aug,
  journal = {Estuaries},
  volume = {26},
  number = {4},
  pages = {1044--1057},
  issn = {0160-8347},
  doi = {10.1007/BF02803362},
  urldate = {2026-02-11},
  abstract = {Bottom-up control, or physical forcing of upper trophic popnlatious\textasciitilde{} is often cited as a major factor regulating marine species. In particular, seabirds are often cited as indicators of relative productivity and health of the marine environment. The degree to which physical forcing plays a dominant role and the mechanisms of effect remain unclear. We test the relatioltship between measures of oceanographic and atmospheric forcing, proxied by conlnlonly available monthly to daily indices, and tile response of populations of a ubiquitous seabird of the Pacific Northwest coastal e n v i r o n m e n t , the conlnlon m u r r e , Uria aalge. We constructed two models: an a n n u a l i z e d bottom-up nlodel that examines the degree to which population response variables\textasciitilde{} including population size, breeding success, and foraging parameters, are correlated with oceanographic forcing at space and time scales relevant to mnrre biology; and a daily direct forcing model that examines the degree to which diet choices reflect specific, local oceanographic signals. Our bottom-up model suggests that murres are regulated by bottom-up forcing\textasciitilde{} and that the strength of the association between physical change and population response may be mediated by density dependence. Our direct forcing model indicated that chick diet is affected by both local and remote parameters, including npwelling, tide, and tile Pacific Decadal Oscillation. We conclude that murres, and seabirds in general, can be used as indicators of local to basinwide physical change, but only under certain conditious: the life history of the species, and the specific local population, must be well known; a conceptual model that links life history traits to measures of physical change at biologically relevant space and time scales must be developed; and larger populations that are more apt to show density-dependent effects should be selected.},
  copyright = {http://www.springer.com/tdm},
  langid = {english},
  file = {/Users/markusmin/Zotero/storage/GJH98MNQ/Parrish and Zador - 2003 - Seabirds as indicators An exploratory analysis of physical forcing in the Pacific Northwest coastal.pdf}
}

