@article{Patrick2015,
  title = {Myths That {{Continue}} to {{Impede Progress}} in {{Ecosystem-Based Fisheries Management}}},
  author = {Patrick, Wesley S. and Link, Jason S.},
  year = 2015,
  journal = {Fisheries},
  volume = {40},
  number = {4},
  pages = {155--160},
  issn = {03632415},
  doi = {10.1080/03632415.2015.1024308},
  abstract = {Ecosystem-based fisheries management has been perceived as something desirable but pragmatically unachievable due to several impediments identified earlier during its implementation phase. Over the years, many of these impediments have been resolved but not well communicated to stakeholders, managers, scientists, and policymakers. As a result, several past impediments to implementing ecosystem-based fisheries management have taken on a mythical status. Here we identify six common myths, address why they in fact no longer impede ecosystem-based fisheries management, and propose solutions for moving forward. We assert that these myths need not continue to exist and that improved approaches for fisheries are indeed feasible.},
  file = {/Users/markusmin/Zotero/storage/5PAKC78D/Myths that Continue to Impede Progress in Ecosystem Based Fisheries Management.pdf}
}

