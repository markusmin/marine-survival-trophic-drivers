@article{Taberlet2012a,
  title = {Towards Next-Generation Biodiversity Assessment Using {{DNA}} Metabarcoding},
  author = {Taberlet, Pierre and Coissac, Eric and Pompanon, Francois and Brochmann, Christian and Willerslev, Eske},
  year = 2012,
  volume = {33},
  pages = {2045--2050},
  abstract = {Virtually all empirical ecological studies require species identification during data collection. DNA metabarcoding refers to the automated identification of multiple species from a single bulk sample containing entire organisms or from a single environmental sample containing degraded DNA (soil, water, faeces, etc.). It can be implemented for both modern and ancient environmental samples. The availability of next-generation sequencing platforms and the ecologists' need for high-throughput taxon identification have facilitated the emergence of DNA metabarcod-ing. The potential power of DNA metabarcoding as it is implemented today is limited mainly by its dependency on PCR and by the considerable investment needed to build comprehensive taxonomic reference libraries. Further developments associated with the impressive progress in DNA sequencing will eliminate the currently required DNA amplification step, and comprehensive tax-onomic reference libraries composed of whole organellar genomes and repetitive ribosomal nuclear DNA can be built based on the well-curated DNA extract collections maintained by standardized barcoding initiatives. The near-term future of DNA metabarcoding has an enormous potential to boost data acquisition in biodiversity research.},
  keywords = {capture probes,DNA-based species identifica-tion,next-generation DNA sequencing},
  file = {/Users/markusmin/Zotero/storage/J4YK962R/TABERLET_et_al-2012-Molecular_Ecology.pdf}
}

