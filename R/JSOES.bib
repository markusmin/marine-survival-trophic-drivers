  author = {Power, Mary E. and Tilman, David and Estes, James A. and Menge, Bruce A. and Bond, William J. and Mills, L. Scott and Daily, Gretchen and Castilla, Juan Carlos and Lubchenco, Jane and Paine, Robert T.},
