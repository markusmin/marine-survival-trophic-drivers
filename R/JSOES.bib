@article{kapurRangewideContrastManagement2024,
  title = {Range-Wide Contrast in Management Outcomes for Transboundary {{Northeast Pacific}} Sablefish},
  author = {Kapur, Maia S. and Haltuch, M.A. and Connors, B. and Berger, A. and Holt, K. and Marshall, K. and Punt, A. E.},
  year = 2024,
  month = jul,
  journal = {Canadian Journal of Fisheries and Aquatic Sciences},
  volume = {81},
