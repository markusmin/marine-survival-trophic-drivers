@article{Pringle2003,
  title = {What Is Hydrologic Connectivity and Why Is It Ecologically Important?},
  author = {Pringle, Catherine},
  year = 2003,
  journal = {Hydrological Processes},
  volume = {17},
  number = {13},
  pages = {2685--2689},
  issn = {0885-6087},
  doi = {10.1002/hyp.5145},
  abstract = {Hydrologic connectivity ( sensu Pringle, 2001) is used here in an\textbackslash necological context to refer to water-mediated transfer of matter,\textbackslash nenergy and/or organisms within or between elements of the hydrologic\textbackslash ncycle. Hydrologic connectivity is essential to the ecological integrity\textbackslash nof the landscape, and reduction or enhancement of this property by\textbackslash nhumans can have major negative environmental effects. Some of these\textbackslash neffects are immediate, localized and, therefore, obvious. For example,\textbackslash nwith respect to migratory fish, a given dam may act to reduce hydrologic\textbackslash nconnectivity (by preventing or impeding migration up or downstream),\textbackslash nwhereas interbasin river transfers enhance this property by allowing\textbackslash nthe dispersal of fish into river basins outside of their range. Less\textbackslash nobvious, are alterations in hydrologic connectivity that exhibit\textbackslash na time lag and manifest themselves at geographic locations far from\textbackslash nthe source of disturbance. An example concerns the cumulative effect\textbackslash nof dams on transport of the inorganic dissolved solute silica. Dams\textbackslash nand associated impoundments can reduce the transport of this compound,\textbackslash nwhich becomes deposited in the bottoms of reservoirs (Humborg et\textbackslash nal ., 2000). The cumulative effects of many dams along a river can\textbackslash npotentially result in a reduction in the amount of silica delivered\textbackslash nto coastal waters, with consequent negative effects on coastal food\textbackslash nweb structure that contribute to eutrophication (Justic et al .,\textbackslash n1995; Turner et al ., 1998). Management and policy decisions regarding\textbackslash nland-use activities and hydropower development are often made in\textbackslash nthe absence of adequate information on hydrologic connectivity in\textbackslash nthe landscape. Our current knowledge of how this property maintains\textbackslash nthe ecological integrity of 'natural' ecosystems is poor due to:\textbackslash n(1) the inherent complexity of water movement within and between\textbackslash nthe atmosphere and surface-subsurface systems; and (2) the extent\textbackslash nand magnitude of human alterations, which often occur before we understand\textbackslash nhow hydrologic connectivity affects ecological patterns in the landscape\textbackslash n(Pringle and Triska, 2000). Hydrologic connectivity is being altered\textbackslash nat a rate unprecedented in geologic history, contributing to dramatic\textbackslash nlosses in global aquatic biodiversity and associated ecosystem integrity\textbackslash n(e.g. Dudgeon, 2000; Pringle et al ., 2000; Rosenberg et al ., 2000).\textbackslash nHumans have already appropriated one-half of the accessible global\textbackslash nfreshwater runoff and this could climb to 70\% by 2025 (Postel et\textbackslash nal ., 1996).(...)},
  file = {/Users/markusmin/Zotero/storage/UJ25Y6AL/Pringle_2003-Hydrological-Processes.pdf}
}

