@article{Sumaila2011,
  title = {Climate Change Impacts on the Biophysics and Economics of World Fisheries},
  author = {Sumaila, U. Rashid and Cheung, William W.L. and Lam, Vicky W.Y. and Pauly, Daniel and Herrick, Samuel},
