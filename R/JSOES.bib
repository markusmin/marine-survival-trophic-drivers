@article{ovandoImprovingForecastsSockeye2022,
  title = {Improving Forecasts of Sockeye Salmon ( {{{\emph{Oncorhynchus}}}}{\emph{ Nerka}} ) with Parametric and Nonparametric Models},
  author = {Ovando, Daniel and Cunningham, Curry and Kuriyama, Peter and Boatright, Christopher and Hilborn, Ray},
