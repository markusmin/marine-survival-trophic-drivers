@article{Suryan2021,
  title = {Ecosystem Response Persists after a Prolonged Marine Heatwave},
  author = {Suryan, Robert M. and Arimitsu, Mayumi L. and Coletti, Heather A. and Hopcroft, Russell R. and Lindeberg, Mandy R. and Barbeaux, Steven J. and Batten, Sonia D. and Burt, William J. and Bishop, Mary A. and Bodkin, James L. and Brenner, Richard and Campbell, Robert W. and Cushing, Daniel A. and Danielson, Seth L. and Dorn, Martin W. and Drummond, Brie and Esler, Daniel and Gelatt, Thomas and Hanselman, Dana H. and Hatch, Scott A. and Haught, Stormy and Holderied, Kris and Iken, Katrin and Irons, David B. and Kettle, Arthur B. and Kimmel, David G. and Konar, Brenda and Kuletz, Kathy J. and Laurel, Benjamin J. and Maniscalco, John M. and Matkin, Craig and McKinstry, Caitlin A.E. and Monson, Daniel H. and Moran, John R. and Olsen, Dan and Palsson, Wayne A. and Pegau, W. Scott and Piatt, John F. and Rogers, Lauren A. and Rojek, Nora A. and Schaefer, Anne and Spies, Ingrid B. and Straley, Janice M. and Strom, Suzanne L. and Sweeney, Kathryn L. and Szymkowiak, Marysia and Weitzman, Benjamin P. and Yasumiishi, Ellen M. and Zador, Stephani G.},
  year = 2021,
  journal = {Scientific Reports},
  volume = {11},
  number = {1},
  pages = {1--17},
  publisher = {Nature Publishing Group UK},
  issn = {20452322},
  doi = {10.1038/s41598-021-83818-5},
  abstract = {Some of the longest and most comprehensive marine ecosystem monitoring programs were established in the Gulf of Alaska following the environmental disaster of the~Exxon Valdez~oil spill over 30~years ago. These monitoring programs have been successful in assessing recovery from oil spill impacts, and their continuation decades later has now provided an unparalleled assessment of ecosystem responses to another newly emerging global threat, marine heatwaves. The 2014--2016 northeast Pacific marine heatwave (PMH) in the Gulf of Alaska was the longest lasting heatwave globally over the past decade, with some cooling, but also continued warm conditions through 2019. Our analysis of 187 time series from primary production to commercial fisheries and nearshore intertidal to offshore oceanic domains demonstrate abrupt changes across trophic levels, with many responses persisting up to at least 5~years after the onset of the heatwave. Furthermore, our suite of metrics showed novel community-level groupings relative to at least a decade prior to the heatwave. Given anticipated increases in marine heatwaves under current climate projections,~it remains uncertain when or if the Gulf of Alaska ecosystem will return to a pre-PMH state.},
  isbn = {0123456789},
  pmid = {33737519},
  file = {/Users/markusmin/Zotero/storage/TQ39SF2Q/suryan_2021_marineheatwave.pdf}
}

@article{Swain2015,
  title = {Extreme Increases in Natural Mortality Prevent Recovery of Collapsed Fish Populations in a {{Northwest Atlantic}} Ecosystem},
  author = {Swain, Douglas P. and Beno{\^i}t, Hugues P.},
  year = 2015,
  journal = {Marine Ecology Progress Series},
  volume = {519},
  pages = {165--182},
  issn = {01718630},
  doi = {10.3354/meps11012},
  abstract = {Improved understanding of the dynamics of populations at low abundance is needed in the face of global biodiversity loss. We examined the dynamics of depleted demersal fish populations in the southern Gulf of St. Lawrence, Canada. Twenty years ago, a number of these populations collapsed due to overexploitation. Since then, others have declined to low abundance. Despite negligible levels of fishing mortality and strong rates of production of small juvenile fish, these populations have shown no sign of recovery and some continue to decline. Lack of recovery is due to dramatic increases in the natural mortality of larger individuals in these populations. In some of these fishes, natural mortality has risen to levels typical of high-turnover forage fishes rather than long-lived demersal fishes. We hypothesize that these high levels of mortality reflect a 'predator pit' or predation-driven Allee effect, resulting from the severely depleted abundance of these fishes and the high and rising abundance of their marine mammal predators, in particular grey seals. Recovery of collapsed demersal fish populations does not appear to be possible under current conditions in this ecosystem, even in the absence of fishing. Our results indicate a need for more precautionary management regimes in order to avoid population collapses that are not reversible by reducing exploitation.},
  keywords = {Allee effect,Marine fishes,Natural mortality,Population recovery,Predation},
  file = {/Users/markusmin/Zotero/storage/ESLTQVRZ/swain_benoit_2015_cod_M.pdf}
}

